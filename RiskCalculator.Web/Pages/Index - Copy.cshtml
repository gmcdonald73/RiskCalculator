@page
@model IndexModel
@{
    ViewData["Title"] = "Risk Calculator";
}

<h2>Risk Calculator</h2>

<form method="post">

    <div asp-validation-summary="All"></div>

    <div>
        <label>Account Size ($)</label>
        <input asp-for="AccountSize" />
        <span asp-validation-for="AccountSize"></span>
    </div>

    <div>
        <label>Risk % Per Trade</label>
        <input asp-for="RiskPercent" />
        <span asp-validation-for="RiskPercent"></span>
    </div>

    <div>
        <label>Entry Price</label>
        <input asp-for="EntryPrice" />
        <span asp-validation-for="EntryPrice"></span>
    </div>

    <div>
        <label>Stop Price</label>
        <input asp-for="StopPrice" />
        <span asp-validation-for="StopPrice"></span>
    </div>

    <br />
    <button type="submit">Calculate</button>
</form>

@if (Model.PositionSize > 0)
{
    <hr />
    <h3>Results</h3>
    <p>Risk Amount: $@Model.RiskAmount</p>
    <p>Position Size (Units): @Model.PositionSize</p>
}